#!/usr/bin/env bash

# USAGE:
# Just run `git split` with HEAD pointed to the commit you want to split.
# At any time you can cancel out by quitting the interactive patch session
# or exiting your GIT_EDITOR with an empty commit message / nonzero status
# code. Just run `git split` again to resume.

set -e

# If passed a commitish argument, split that commit
if [ -n "$1" ]; then
  SEQ="sd -n1 '^' 'break\n'" # insert "break" before first `pick` command
  git -c sequence.editor="$SEQ" rebase --interactive "$1"
  git-split
  exec git rebase --continue
fi

unstaged_changes_exist() {
  ! git diff --quiet
}

GIT_DIR=$(git root)/.git

if [ -f "$GIT_DIR/split_in_progress" ]; then
  read -r head < "$GIT_DIR/split_in_progress"
else
  head=$(git rev-parse HEAD | tee "$GIT_DIR/split_in_progress")
  mapfile -t added_files < <(git diff-tree --name-only --no-commit-id --diff-filter=A HEAD)

  git reset HEAD^ --quiet

  # Added files will be ignored by --patch unless we explicitly mention them
  if [ ${#added_files[@]} -gt 0 ]; then
    git add --intent-to-add "${added_files[@]}"
  fi
fi

while unstaged_changes_exist; do
  git commit --patch --reedit-message "$head" || exit 1
done

rm -f "$GIT_DIR/split_in_progress"
