#!/usr/bin/env sh

# Ping a host every second until it comes online.
# Optionally notify via ntfy.

set -e

for arg in "$@"; do
  case "$arg" in
    --ntfy) NOTIFY=true;;
    *) HOST="$arg"
  esac
done

if [ -z "$HOST" ]; then
  echo Please provide a host to ping. >&2
  exit 1
fi

# Don't run ntfy if we CTRL-C out of `watch`
trap 'exit' INT

watch --interval 1 --chgexit --exec ping -c1 -W1 -- "$HOST" 1>/dev/null

if [ "$NOTIFY" = 'true' ]; then
  exec ntfy "$HOST is up!"
fi
